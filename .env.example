# ==========================================
# Flask core
# ==========================================
SECRET_KEY=change-this-to-a-long-random-string

# ==========================================
# Frontend (Vercel) / CORS
# ==========================================
FRONTEND_URL=https://your-frontend.vercel.app

# ==========================================
# SMTP / Email
# ==========================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password
RECIPIENT_EMAIL=owner-email@gmail.com

# ==========================================
# Pay Hero
# ==========================================
PAYHERO_BASE_URL=https://backend.payhero.co.ke/api/v2
PAYHERO_USERNAME=your-payhero-username
PAYHERO_PASSWORD=your-payhero-password
PAYHERO_CHANNEL_ID=your-channel-id
PAYHERO_CALLBACK_URL=https://your-backend.onrender.com/api/payhero/callback

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=INFO

# ==========================================
# Storage (optional - for persistence)
# ==========================================
# PostgreSQL URL for persistent storage. If set, uses PostgreSQL instead
# of JSON files. Example: postgresql://user:password@db.host/birthday_db
# On Render, you can use a free tier PostgreSQL or point to Supabase.
# If not set, falls back to JSON files (ephemeral on Render free tier).
DATABASE_URL=

# ==========================================
# Rate Limiter Scaling (optional)
# ==========================================
# Redis URL for distributed rate limiting across multiple workers.
# Example: redis://localhost:6379/0
# If not set, uses in-memory storage (only works with single worker).
REDIS_URL=
