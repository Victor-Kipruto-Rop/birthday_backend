# ==========================================
# APPLICATION
# ==========================================
APP_NAME=Birthday Backend API
APP_ENV=production
APP_DEBUG=False
APP_HOST=0.0.0.0
APP_PORT=10000
TIMEZONE=Africa/Nairobi

# ==========================================
# FLASK
# ==========================================
FLASK_APP=app.py
FLASK_ENV=production
SECRET_KEY=GENERATE_A_RANDOM_64_CHARACTER_SECRET

# ==========================================
# FRONTEND
# ==========================================
FRONTEND_URL=https://victor-kipruto-rop.github.io/modern_portfolio/
ALLOWED_ORIGINS=https://victor-kipruto-rop.github.io,https://birthday-alpha-taupe-49.vercel.app

# ==========================================
# PAYHERO
# ==========================================
PAYHERO_BASE_URL=https://backend.payhero.co.ke/api/v2/
PAYHERO_USERNAME=YOUR_PAYHERO_API_USERNAME
PAYHERO_PASSWORD=YOUR_PAYHERO_API_PASSWORD
PAYHERO_ACCOUNT_ID=9048
PAYHERO_CHANNEL_ID=10564
PAYHERO_PROVIDER=m-pesa
PAYHERO_CALLBACK_URL=https://birthday-backend-s1b7.onrender.com/api/payhero/callback

# ==========================================
# EMAIL (SMTP)
# ==========================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
RECEIVER_EMAIL=your_email@gmail.com
SMTP_USE_TLS=True

# ==========================================
# PAYMENT
# ==========================================
CURRENCY=KES
MIN_GIFT_AMOUNT=10
MAX_GIFT_AMOUNT=150000

# ==========================================
# SECURITY
# ==========================================
RATE_LIMIT=100/hour
REQUEST_TIMEOUT=30
VERIFY_SSL=True
MAX_CONTENT_LENGTH=5242880

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ==========================================
# REDIS (Optional)
# ==========================================
REDIS_URL=

# ==========================================
# FEATURES
# ==========================================
ENABLE_EMAIL=True
ENABLE_PAYMENTS=True
ENABLE_REQUEST_LOGGING=True
ENABLE_SWAGGER=False
ENABLE_METRICS=False
